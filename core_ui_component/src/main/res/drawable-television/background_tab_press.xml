<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape>
            <solid android:color="@color/tv_focus_overlay_color" />
            <stroke
                android:width="@dimen/tv_focus_stroke_width"
                android:color="@color/tv_focus_stroke_color" />
        </shape>
    </item>

    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/tv_pressed_overlay_color" />
        </shape>
    </item>

    <item android:drawable="@android:color/transparent" />
</selector>
