<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <layer-list>
            <item>
                <shape>
                    <solid android:color="@color/item_bg_color" />
                    <stroke
                        android:width="0.8dp"
                        android:color="@color/item_border_color" />
                    <corners android:radius="3dp" />
                </shape>
            </item>

            <item>
                <shape>
                    <solid android:color="@color/tv_focus_overlay_color" />
                    <stroke
                        android:width="@dimen/tv_focus_stroke_width"
                        android:color="@color/tv_focus_stroke_color" />
                    <corners android:radius="3dp" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/tv_pressed_overlay_color" />
            <corners android:radius="3dp" />
        </shape>
    </item>

    <item>
        <shape>
            <solid android:color="@color/item_bg_color" />
            <stroke
                android:width="0.8dp"
                android:color="@color/item_border_color" />
            <corners android:radius="3dp" />
        </shape>
    </item>
</selector>
